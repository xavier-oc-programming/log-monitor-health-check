# Copy this file to config.yaml and fill in your settings.
# NEVER put your actual credentials in this file.
# Set EMAIL_USERNAME and EMAIL_PASSWORD as environment variables instead.

smtp:
  host: smtp.gmail.com
  port: 587
  username: ""    # set via EMAIL_USERNAME environment variable
  password: ""    # set via EMAIL_PASSWORD environment variable

email:
  from: "Log Monitor <your_email@gmail.com>"
  to:
    - recipient@example.com
  subject_prefix: "Log Health Report"

analysis:
  default_hours: 24
  error_rate_threshold: 0.10
  spike_window_minutes: 5
  top_errors_n: 10
  spike_start_entry: 800
  spike_end_entry: 900
  spike_error_prob: 0.40

log_generation:
  n_entries: 2000
  seed: 42
  severity_weights:
    DEBUG: 0.20
    INFO: 0.55
    WARNING: 0.15
    ERROR: 0.08
    CRITICAL: 0.02
